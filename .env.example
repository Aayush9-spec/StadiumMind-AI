# StadiumMind AI Environment Configuration Example

# API Key for Gemini 2.5 Flash API Orchestrator
# Get your key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Backend FastAPI Settings
HOST=0.0.0.0
PORT=8000
DEBUG=True

# Security Settings
# Generate a secret key: openssl rand -hex 32
API_BEARER_TOKEN=stadiummind_eval_secret_token_12345
CORS_ORIGINS=http://localhost:3000,https://stadiummind-ai.vercel.app

# Optional integrations or analytics
RATE_LIMIT_PER_MINUTE=60
